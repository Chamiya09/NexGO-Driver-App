{
  "expo": {
    "name": "nexgo",
    "slug": "nexgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NexGO Driver to use your current location for ride matching and navigation.",
          "locationAlwaysAndWhenInUsePermission": "Allow NexGO Driver to keep your live ride location updated while trips are active, even when the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NexGO Driver to use your camera for profile photos and required driver documents."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow NexGO Driver to access photos for profile pictures and document uploads.",
          "savePhotosPermission": "Allow NexGO Driver to save captured document photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NexGO Driver to select a profile image from your gallery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
