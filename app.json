{
  "expo": {
    "name": "nexgo",
    "slug": "nexgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow NexGO Driver to use your current location for ride matching and navigation.",
        "NSCameraUsageDescription": "Allow NexGO Driver to use your camera for profile photos and required driver documents.",
        "NSPhotoLibraryUsageDescription": "Allow NexGO Driver to access photos for profile pictures and document uploads."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.chamiya09.nexgo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NexGO Driver to use your current location for ride matching and navigation."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NexGO Driver to select profile and document images from your gallery.",
          "cameraPermission": "Allow NexGO Driver to use your camera for required driver and vehicle document photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4fcd738-402d-456f-960d-d203e867870d"
      }
    }
  }
}
